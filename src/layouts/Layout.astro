---
import { CartDrawer } from "../components/CartDrawer";
import Footer from "../components/Footer.astro";
import { MobileMenu } from "../components/MobileMenu";
import Navbar from "../components/Navbar.astro";
import "../index.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const navItems = ["Footwear", "Apparel", "Accessories", "Training"];
const tagline = "Engineered for relentless performance. Shop the latest athletic gear.";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
    <meta name="description" content="AXIS Training — Engineered for relentless performance. Shop the latest athletic gear." />
    <meta name="theme-color" content="#0f172a" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | AXIS TRAINING`} />
    <meta property="og:description" content={tagline} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AXIS TRAINING`} />
    <meta name="twitter:description" content={tagline} />
		<title>{title} | AXIS TRAINING</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="bg-brand-dark text-white font-sans selection:bg-brand-primary selection:text-brand-dark">
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
      <div class="absolute top-[-20%] right-[-10%] w-[60%] h-[60%] rounded-full bg-brand-primary opacity-[0.05] blur-[100px]" />
      <div class="absolute top-[40%] left-[-20%] w-[50%] h-[50%] rounded-full bg-brand-secondary opacity-[0.03] blur-[100px]" />
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0MCIgaGVpZ2h0PSI0MCI+CiAgPHBhdGggZD0iTTAgNDBMNDAgMCIgc3Ryb2tlPSJibGFjayIgc3Ryb2tlLXdpZHRoPSIyIiBvcGFjaXR5PSIwLjEiLz4KPC9zdmc+')] opacity-20 mix-blend-overlay" />
    </div>

    <Navbar navItems={navItems} />

    <MobileMenu client:idle navItems={navItems} />
    <CartDrawer client:idle />

    <main class="relative z-10 w-full min-h-screen">
      <slot />
    </main>

    <Footer />
	</body>
</html>
