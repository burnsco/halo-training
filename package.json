    "react-router-dom": "^7.14.1",
    "wrangler": "^4.84.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.8",
    "autoprefixer": "^10.5.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
