{
  "name": "halo-training",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix . && oxfmt",
